# Server Environment
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="mongodb://localhost:27017/rack-calculator"

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
